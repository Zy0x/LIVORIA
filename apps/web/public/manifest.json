{
  "name": "LIVORIA - Living Information & Organized Records Archive",
  "short_name": "LIVORIA",
  "description": "Personal archive app untuk tagihan, anime, donghua, waifu, dan obat-obatan.",
  "start_url": "/",
  "scope": "/",
  "id": "/",
  "display": "standalone",
  "display_override": ["standalone", "window-controls-overlay", "minimal-ui"],
  "orientation": "any",
  "background_color": "#f4f5f0",
  "theme_color": "#2d5040",
  "lang": "id",
  "dir": "ltr",
  "categories": ["productivity", "utilities", "finance", "entertainment"],
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "handle_links": "preferred",
  "edge_side_panel": {
    "preferred_width": 400
  },
  "icons": [
    {
      "src": "/icons/icon-128x128.png",
      "sizes": "128x128",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-256x256.png",
      "sizes": "256x256",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon.png",
      "sizes": "256x256",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "Tagihan",
      "short_name": "Tagihan",
      "url": "/tagihan",
      "description": "Lihat dan kelola tagihan",
      "icons": [{ "src": "/icons/icon-128x128.png", "sizes": "128x128" }]
    },
    {
      "name": "Anime",
      "short_name": "Anime",
      "url": "/anime",
      "description": "Database anime",
      "icons": [{ "src": "/icons/icon-128x128.png", "sizes": "128x128" }]
    },
    {
      "name": "Donghua",
      "short_name": "Donghua",
      "url": "/donghua",
      "description": "Database donghua",
      "icons": [{ "src": "/icons/icon-128x128.png", "sizes": "128x128" }]
    }
  ],
  "prefer_related_applications": false,
  "related_applications": []
}
