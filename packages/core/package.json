{
  "name": "@livoria/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./contracts": {
      "import": "./src/contracts/index.ts",
      "types": "./src/contracts/index.ts"
    },
    "./domain": {
      "import": "./src/domain/index.ts",
      "types": "./src/domain/index.ts"
    },
    "./formatters": {
      "import": "./src/formatters/index.ts",
      "types": "./src/formatters/index.ts"
    },
    "./storage": {
      "import": "./src/storage/index.ts",
      "types": "./src/storage/index.ts"
    },
    "./utils": {
      "import": "./src/utils/index.ts",
      "types": "./src/utils/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit"
  }
}
